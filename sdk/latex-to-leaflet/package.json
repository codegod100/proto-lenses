{
  "name": "@nandithebull/latex-to-leaflet",
  "version": "0.30.0",
  "description": "TypeScript SDK for the latex-to-leaflet converter",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint ."
  },
  "devDependencies": {
    "oxlint": "^1.60.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/panproto/proto-lenses.git",
    "directory": "sdk/latex-to-leaflet"
  },
  "keywords": [
    "panproto",
    "latex",
    "leaflet",
    "converter"
  ]
}
